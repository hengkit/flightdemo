# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# AISStream API Key (optional)
# Get your free API key at https://aisstream.io
# If not provided, ship tracking will be disabled
# AISSTREAM_API_KEY="your-api-key"

# Pantheon Content Publisher
# Required for airline information lookup
# NEXT_PUBLIC_PCC_TOKEN="your-token"
# NEXT_PUBLIC_PCC_SITE_ID="your-site-id"
# NEXT_PUBLIC_PCC_COLLECTION_ID="your-collection-id" # Optional, defaults to airlines collection

# N2YO API Key (optional)
# Required for satellite tracking
# Get your free API key at https://www.n2yo.com/api/
# N2YO_API_KEY="your-api-key"

# Refresh Intervals (in milliseconds)
# Articles cache duration (server-side)
ARTICLES_CACHE_DURATION=60000
# Articles stale time (client-side)
NEXT_PUBLIC_ARTICLES_STALE_TIME=60000
# Aircraft details stale time (client-side)
NEXT_PUBLIC_AIRCRAFT_DETAILS_STALE_TIME=300000
# Flight data refetch interval (client-side)
NEXT_PUBLIC_FLIGHTS_REFETCH_INTERVAL=60000
# Weather data refetch interval (client-side)
NEXT_PUBLIC_WEATHER_REFETCH_INTERVAL=300000
# Ship data refetch interval (client-side)
NEXT_PUBLIC_SHIPS_REFETCH_INTERVAL=60000
# Satellite data refetch interval (client-side)
NEXT_PUBLIC_SATELLITES_REFETCH_INTERVAL=60000
# Map bounds update debounce (client-side)
NEXT_PUBLIC_MAP_BOUNDS_DEBOUNCE=30000

# Example:
# SERVERVAR="foo"
# NEXT_PUBLIC_CLIENTVAR="bar"
